# Default compose profiles for the dev harness. NO SECRETS in this file.
# `docker compose -f docker/docker-compose.dev.yml up -d` boots the 6.x pair PLUS the
# BFF's Postgres (:5433) — the backend needs it since M4 (Flyway/audit at startup).
# Add engines with e.g. `--profile flowable-7` (the CLI flag overrides this default).
COMPOSE_PROFILES=flowable-6,postgres
