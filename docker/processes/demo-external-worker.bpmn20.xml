<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://inspector.io/demo">

  <!-- v1.x #7: parks on an EXTERNAL-WORKER service task (Flowable 6.8+, flowable:type=
       "external-worker"). No worker is registered for its topic, so starting an instance
       leaves an UNACQUIRED external-worker job in the fifth queue (ACT_RU_EXTERNAL_JOB) —
       the read-only visibility fixture for the External Worker lane. The element is
       unsupported pre-6.8, so seed.sh deploys this ONLY to the 6.8+ engines, never legacy. -->
  <process id="demoExternalWorker" name="Demo External Worker" isExecutable="true">
    <startEvent id="start"/>
    <sequenceFlow id="flow1" sourceRef="start" targetRef="chargeViaWorker"/>
    <serviceTask id="chargeViaWorker" name="Charge via worker"
                 flowable:type="external-worker" flowable:topic="inspectorDemo"/>
    <sequenceFlow id="flow2" sourceRef="chargeViaWorker" targetRef="end"/>
    <endEvent id="end"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_demoExternalWorker">
    <bpmndi:BPMNPlane id="BPMNPlane_demoExternalWorker" bpmnElement="demoExternalWorker">
      <bpmndi:BPMNShape id="BPMNShape_start" bpmnElement="start">
        <omgdc:Bounds x="100" y="100" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_chargeViaWorker" bpmnElement="chargeViaWorker">
        <omgdc:Bounds x="180" y="85" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_end" bpmnElement="end">
        <omgdc:Bounds x="330" y="101" width="28" height="28"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_flow1" bpmnElement="flow1">
        <omgdi:waypoint x="130" y="115"/>
        <omgdi:waypoint x="180" y="115"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_flow2" bpmnElement="flow2">
        <omgdi:waypoint x="280" y="115"/>
        <omgdi:waypoint x="330" y="115"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
