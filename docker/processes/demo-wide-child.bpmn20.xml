<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://inspector.io/demo">
  <!-- F-G1 child: parks on a user task so the wide parent's 60 children stay ACTIVE
       (hierarchy breadth cap R-SEM-19 + timeline sub-lane fixtures). -->
  <process id="demoWideChild" name="Wide-parent child (waits on review)" isExecutable="true">
    <startEvent id="start"/>
    <sequenceFlow id="f1" sourceRef="start" targetRef="reviewItem"/>
    <userTask id="reviewItem" name="Review fan-out item" flowable:assignee="kermit"/>
    <sequenceFlow id="f2" sourceRef="reviewItem" targetRef="end"/>
    <endEvent id="end"/>
  </process>
  <bpmndi:BPMNDiagram id="diag">
    <bpmndi:BPMNPlane id="plane" bpmnElement="demoWideChild">
      <bpmndi:BPMNShape id="s_start" bpmnElement="start">
        <omgdc:Bounds x="100" y="100" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_review" bpmnElement="reviewItem">
        <omgdc:Bounds x="180" y="90" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_end" bpmnElement="end">
        <omgdc:Bounds x="330" y="100" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="e_f1" bpmnElement="f1">
        <omgdi:waypoint x="130" y="115"/>
        <omgdi:waypoint x="180" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e_f2" bpmnElement="f2">
        <omgdi:waypoint x="280" y="120"/>
        <omgdi:waypoint x="330" y="115"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
