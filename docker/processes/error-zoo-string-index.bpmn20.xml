<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://inspector.io/demo">

  <!-- Error-zoo corpus fixture (TEST-STRATEGY §4): start with a SHORT string variable
       orderRef — ${orderRef.substring(100)} throws StringIndexOutOfBoundsException whose
       message embeds per-instance lengths/indices. Distinct instances must still collapse
       into ONE normalized signature (the ID/digit-stripping proof). R1/PT1S = fast DLQ. -->
  <process id="zooStringIndex" name="Error Zoo: string index out of bounds" isExecutable="true">
    <startEvent id="start"/>
    <sequenceFlow id="flow1" sourceRef="start" targetRef="failingTask"/>
    <!-- Retry cycle MUST be the extension ELEMENT — the attribute form parses but is
         silently ignored (proven on flowable-rest 6.8: attribute → default R3/PT10S). -->
    <serviceTask id="failingTask" name="Slice order ref"
                 flowable:async="true"
                 flowable:expression="${orderRef.substring(100)}">
      <extensionElements>
        <flowable:failedJobRetryTimeCycle>R1/PT1S</flowable:failedJobRetryTimeCycle>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="flow2" sourceRef="failingTask" targetRef="end"/>
    <endEvent id="end"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_zooStringIndex">
    <bpmndi:BPMNPlane id="BPMNPlane_zooStringIndex" bpmnElement="zooStringIndex">
      <bpmndi:BPMNShape id="BPMNShape_start" bpmnElement="start">
        <omgdc:Bounds x="100" y="100" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_failingTask" bpmnElement="failingTask">
        <omgdc:Bounds x="180" y="85" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_end" bpmnElement="end">
        <omgdc:Bounds x="330" y="101" width="28" height="28"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_flow1" bpmnElement="flow1">
        <omgdi:waypoint x="130" y="115"/>
        <omgdi:waypoint x="180" y="115"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_flow2" bpmnElement="flow2">
        <omgdi:waypoint x="280" y="115"/>
        <omgdi:waypoint x="330" y="115"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
