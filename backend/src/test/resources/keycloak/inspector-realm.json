{
  "realm": "inspector",
  "enabled": true,
  "accessTokenLifespan": 300,
  "groups": [
    { "name": "flowable-admins" },
    { "name": "orders-l1" }
  ],
  "clientScopes": [
    {
      "name": "groups",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "inspector-bff",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "test-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "defaultClientScopes": ["acr", "basic", "email", "profile", "roles", "web-origins", "groups"]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.test",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "alice-pw", "temporary": false }],
      "groups": ["/flowable-admins", "/orders-l1"]
    }
  ]
}
